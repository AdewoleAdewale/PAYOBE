<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:yummy="clr-namespace:Xamarin.Forms.PancakeView;assembly=Xamarin.Forms.PancakeView"
             xmlns:renderers="clr-namespace:PAYYOBE.Services"
             x:Class="PAYYOBE.Views.Password"
             Padding="0"
             BackgroundColor="#80000000"
             NavigationPage.HasNavigationBar="False">

    <!-- Full-screen dimmed backdrop + slide-up sheet -->
    <Grid>

        <!-- Tap backdrop to go back -->
        <BoxView BackgroundColor="#80000000" HorizontalOptions="Fill" VerticalOptions="Fill">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Bottom sheet sits at the bottom of the grid -->
        <yummy:PancakeView VerticalOptions="End"
                           HorizontalOptions="Fill"
                           CornerRadius="28,28,0,0"
                           HasShadow="True"
                           Elevation="24"
                           Padding="0,0,0,0">
            <yummy:PancakeView.BackgroundGradientStops>
                <yummy:GradientStopCollection>
                    <yummy:GradientStop Color="#011C0E" Offset="0.0"/>
                    <yummy:GradientStop Color="#003D22" Offset="1.0"/>
                </yummy:GradientStopCollection>
            </yummy:PancakeView.BackgroundGradientStops>

            <StackLayout Spacing="0">

                <!-- Drag handle -->
                <BoxView WidthRequest="44" HeightRequest="5" CornerRadius="3"
                         BackgroundColor="#40FFFFFF"
                         HorizontalOptions="Center" Margin="0,14,0,0"/>

                <!-- Sheet header -->
                <Grid ColumnDefinitions="Auto,*,Auto" Padding="22,18,22,0">
                    <yummy:PancakeView Grid.Column="0" BackgroundColor="#20C8941A"
                                       CornerRadius="14" WidthRequest="44" HeightRequest="44"
                                       BorderColor="#40C8941A" BorderThickness="1"
                                       VerticalOptions="Center">
                        <Label Text="🔐" FontSize="20"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </yummy:PancakeView>

                    <StackLayout Grid.Column="1" Margin="12,0,0,0"
                                 VerticalOptions="Center" Spacing="2">
                        <Label Text="CHANGE PASSWORD"
                               TextColor="White" FontSize="17" FontAttributes="Bold"
                               CharacterSpacing="0.8"/>
                        <Label Text="Update your account security credentials"
                               TextColor="#80AAFFAA" FontSize="10"/>
                    </StackLayout>

                    <!-- Close button -->
                    <yummy:PancakeView Grid.Column="2" BackgroundColor="#18FFFFFF"
                                       CornerRadius="12" WidthRequest="38" HeightRequest="38"
                                       VerticalOptions="Center">
                        <Label Text="✕" FontSize="16" FontAttributes="Bold"
                               TextColor="#80FFFFFF"
                               HorizontalOptions="Center" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </yummy:PancakeView>
                </Grid>

                <!-- Divider -->
                <BoxView HeightRequest="1" BackgroundColor="#15FFFFFF" Margin="22,14,22,0"/>

                <ScrollView>
                    <StackLayout Spacing="0" Padding="22,18,22,40">

                        <!-- Requirements card -->
                        <yummy:PancakeView CornerRadius="16" BackgroundColor="#1AFFFFFF"
                                           Padding="16,14" Margin="0,0,0,20"
                                           BorderColor="#20C8941A" BorderThickness="1">
                            <StackLayout Spacing="8">
                                <Label Text="PASSWORD REQUIREMENTS" TextColor="#C8941A"
                                       FontSize="9" FontAttributes="Bold" CharacterSpacing="2"/>

                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <Label Grid.Column="0" Text="›" TextColor="#C8941A"
                                           FontSize="16" VerticalOptions="Start"/>
                                    <Label Grid.Column="1" Text="Minimum 6 characters"
                                           TextColor="#A8D5B9" FontSize="12"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <Label Grid.Column="0" Text="›" TextColor="#C8941A"
                                           FontSize="16" VerticalOptions="Start"/>
                                    <Label Grid.Column="1" Text="At least one uppercase letter (A–Z)"
                                           TextColor="#A8D5B9" FontSize="12"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <Label Grid.Column="0" Text="›" TextColor="#C8941A"
                                           FontSize="16" VerticalOptions="Start"/>
                                    <Label Grid.Column="1" Text="At least one special character (!@#$%)"
                                           TextColor="#A8D5B9" FontSize="12"/>
                                </Grid>
                            </StackLayout>
                        </yummy:PancakeView>

                        <!-- Current Password field -->
                        <Label Text="CURRENT PASSWORD" TextColor="#80AAFFAA"
                               FontSize="9" FontAttributes="Bold" CharacterSpacing="2"
                               Margin="4,0,0,6"/>
                        <yummy:PancakeView CornerRadius="16" BackgroundColor="#0FFFFFFF"
                                           HasShadow="False" HeightRequest="58" Padding="0"
                                           BorderColor="#25FFFFFF" BorderThickness="1"
                                           Margin="0,0,0,16">
                            <Grid ColumnDefinitions="54,*" VerticalOptions="FillAndExpand">
                                <yummy:PancakeView Grid.Column="0" CornerRadius="16,0,0,16"
                                                   BackgroundColor="#15C8941A">
                                    <Label Text="🔒" FontSize="20"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </yummy:PancakeView>
                                <renderers:BorderlessEntry Grid.Column="1"
                                    x:Name="OldPasswordEntry"
                                    Placeholder="Enter current password"
                                    PlaceholderColor="#50AAFFAA"
                                    FontSize="14" FontAttributes="Bold"
                                    TextColor="White" IsPassword="True"
                                    ClearButtonVisibility="WhileEditing"
                                    Margin="14,0,12,0"
                                    VerticalOptions="Center"/>
                            </Grid>
                        </yummy:PancakeView>

                        <!-- New Password field -->
                        <Label Text="NEW PASSWORD" TextColor="#80AAFFAA"
                               FontSize="9" FontAttributes="Bold" CharacterSpacing="2"
                               Margin="4,0,0,6"/>
                        <yummy:PancakeView CornerRadius="16" BackgroundColor="#0FFFFFFF"
                                           HasShadow="False" HeightRequest="58" Padding="0"
                                           BorderColor="#25FFFFFF" BorderThickness="1"
                                           Margin="0,0,0,20">
                            <Grid ColumnDefinitions="54,*" VerticalOptions="FillAndExpand">
                                <yummy:PancakeView Grid.Column="0" CornerRadius="16,0,0,16"
                                                   BackgroundColor="#15C8941A">
                                    <Label Text="🔓" FontSize="20"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </yummy:PancakeView>
                                <renderers:BorderlessEntry Grid.Column="1"
                                    x:Name="ConfirmPassword"
                                    Placeholder="Enter new password"
                                    PlaceholderColor="#50AAFFAA"
                                    FontSize="14" FontAttributes="Bold"
                                    TextColor="White" IsPassword="True"
                                    ClearButtonVisibility="WhileEditing"
                                    Margin="14,0,12,0"
                                    VerticalOptions="Center"/>
                            </Grid>
                        </yummy:PancakeView>

                        <!-- Security notice -->
                        <yummy:PancakeView CornerRadius="14" BackgroundColor="#0FFFFFFF"
                                           Padding="14,10" Margin="0,0,0,24"
                                           BorderColor="#15FFFFFF" BorderThickness="1">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="ℹ️" FontSize="14"
                                       VerticalOptions="Center"/>
                                <Label Grid.Column="1"
                                       Text="You will be logged out automatically after a successful password change."
                                       TextColor="#80AAFFAA" FontSize="11" LineBreakMode="WordWrap"/>
                            </Grid>
                        </yummy:PancakeView>

                        <!-- Submit button -->
                        <yummy:PancakeView CornerRadius="18" HeightRequest="60" HasShadow="True"
                                           Elevation="6">
                            <yummy:PancakeView.BackgroundGradientStops>
                                <yummy:GradientStopCollection>
                                    <yummy:GradientStop Color="#C8941A" Offset="0.0"/>
                                    <yummy:GradientStop Color="#9E6F0A" Offset="1.0"/>
                                </yummy:GradientStopCollection>
                            </yummy:PancakeView.BackgroundGradientStops>
                            <yummy:PancakeView.GestureRecognizers>
                                <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped_1"/>
                            </yummy:PancakeView.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="20,0"
                                  HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">
                                <Label Grid.Column="0" Text="🔐" FontSize="20" TextColor="White"
                                       VerticalOptions="Center"/>
                                <StackLayout Grid.Column="1" HorizontalOptions="Center"
                                             VerticalOptions="Center" Spacing="2">
                                    <Label Text="UPDATE PASSWORD" TextColor="White"
                                           FontSize="14" FontAttributes="Bold"
                                           CharacterSpacing="1.2" HorizontalOptions="Center"/>
                                    <Label Text="Secure your PAYYOBE account"
                                           TextColor="#80FFFFFF" FontSize="9" HorizontalOptions="Center"/>
                                </StackLayout>
                                <yummy:PancakeView Grid.Column="2" CornerRadius="12"
                                                   BackgroundColor="#20FFFFFF"
                                                   WidthRequest="36" HeightRequest="36"
                                                   VerticalOptions="Center">
                                    <Label Text="→" TextColor="White" FontSize="16"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </yummy:PancakeView>
                            </Grid>
                        </yummy:PancakeView>

                        <!-- Footer -->
                        <StackLayout HorizontalOptions="Center" Spacing="4" Margin="0,18,0,0">
                            <BoxView Color="#15FFFFFF" HeightRequest="1" Margin="40,0"/>
                            <Label Text="YOBE INTERNAL REVENUE SERVICE"
                                   TextColor="#40C8941A" FontSize="9" FontAttributes="Bold"
                                   CharacterSpacing="2" HorizontalOptions="Center"/>
                        </StackLayout>

                    </StackLayout>
                </ScrollView>
            </StackLayout>
        </yummy:PancakeView>
    </Grid>
</ContentPage>
