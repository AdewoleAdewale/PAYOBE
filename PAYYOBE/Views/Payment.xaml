<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PAYYOBE.Views.Payment"     
             BackgroundColor="Transparent"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="Green" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="15" />
                <Setter Property="HeightRequest" Value="50" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Margin" Value="0,5" />
            </Style>

            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="TextColor" Value="ForestGreen" />
                <Setter Property="BorderWidth" Value="2" />
                <Setter Property="BorderColor" Value="ForestGreen" />
                <Setter Property="CornerRadius" Value="15" />
                <Setter Property="HeightRequest" Value="50" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Margin" Value="0,5" />
            </Style>

            <!-- Reprint button style — amber/orange to stand out clearly -->
            <Style x:Key="ReprintButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#E67E22" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="15" />
                <Setter Property="HeightRequest" Value="50" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Margin" Value="0,5" />
            </Style>

            <Style x:Key="InputFrameStyle" TargetType="Frame">
                <Setter Property="HasShadow" Value="True" />
                <Setter Property="BorderColor" Value="LightGray" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="15,10" />
                <Setter Property="BackgroundColor" Value="#F8F9FA" />
                <Setter Property="Margin" Value="0,5" />
            </Style>

            <Style x:Key="LabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="#2D3436" />
                <Setter Property="Margin" Value="0,10,0,5" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#70000000" Offset="0.0" />
                <GradientStop Color="#90000000" Offset="0.5" />
                <GradientStop Color="#B0000000" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnBackgroundTapped" />
        </Grid.GestureRecognizers>

        <!-- Loading Indicator -->
        <StackLayout x:Name="LoadingContainer" 
                     IsVisible="False" 
                     VerticalOptions="Center" 
                     HorizontalOptions="Center"
                     BackgroundColor="#80000000"
                     Padding="30,20"
                     Spacing="15">
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsVisible="False"
                               IsRunning="False"
                               Color="ForestGreen"
                               Scale="1.8" />
            <Label Text="Processing Payment..."
                   TextColor="White"
                   FontSize="16"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
        </StackLayout>

        <!-- Sheet Container -->
        <Frame x:Name="SheetFrame"
               VerticalOptions="End" 
               HorizontalOptions="FillAndExpand"
               BackgroundColor="White"
               CornerRadius="15"
               HasShadow="True"
               Padding="0"
               Margin="8,0,8,8"
               TranslationY="250">

            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnSheetTapped" />
            </Frame.GestureRecognizers>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Drag Handle -->
                <StackLayout x:Name="DragHandleArea"
                             Grid.Row="0" 
                             Padding="0,10,0,15" 
                             BackgroundColor="Transparent"
                             HeightRequest="50">
                    <StackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSheetTapped" />
                    </StackLayout.GestureRecognizers>
                    <BoxView x:Name="DragHandle"
                             HeightRequest="6"
                             WidthRequest="50"
                             BackgroundColor="#E0E0E0"
                             HorizontalOptions="Center"
                             VerticalOptions="Start"
                             CornerRadius="3" />
                </StackLayout>

                <!-- Sheet Content -->
                <ScrollView Grid.Row="1" 
                            Padding="25,5,25,35" 
                            VerticalScrollBarVisibility="Never">
                    <StackLayout Spacing="10" Orientation="Vertical">

                        <!-- Header -->
                        <StackLayout Spacing="10" Margin="0,0,0,10">
                            <StackLayout.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSheetTapped" />
                            </StackLayout.GestureRecognizers>

                            <Image Source="yobe" 
                                   Aspect="AspectFit"
                                   HeightRequest="100"
                                   WidthRequest="100"
                                   HorizontalOptions="Center"
                                   Margin="0,0,0,5"/>

                            <Label Text="YOBE JUDICIARY PAYMENT" 
                                   FontSize="22" 
                                   FontAttributes="Bold" 
                                   HorizontalOptions="Center"
                                   TextColor="#2D3436" />

                            <Label Text="SECURE PAYMENT PROCESSING" 
                                   FontSize="14" 
                                   FontAttributes="Bold" 
                                   HorizontalOptions="Center"
                                   TextColor="ForestGreen"
                                   Margin="0,-5,0,0" />
                        </StackLayout>

                        <!-- Invoice Number Input -->
                        <StackLayout Spacing="8">
                            <Label Text="Invoice Number" 
                                   Style="{StaticResource LabelStyle}"/>
                            <Frame x:Name="TokenInputFrame"
                                   Style="{StaticResource InputFrameStyle}"
                                   HeightRequest="50">
                                <Entry x:Name="inputtoken"
                                       Placeholder="Enter your Invoice Number" 
                                       HorizontalOptions="FillAndExpand"
                                       HeightRequest="50"
                                       BackgroundColor="Transparent"
                                       FontSize="16"
                                       TextChanged="OnTokenTextChanged"
                                       Completed="OnTokenCompleted"
                                       MaxLength="30"
                                       ClearButtonVisibility="WhileEditing"
                                       PlaceholderColor="Gray" />
                            </Frame>
                            <Label x:Name="TokenHintLabel"
                                   Text="Format: Alphanumeric (6-20 characters)"
                                   FontSize="12"
                                   TextColor="#74B9FF"
                                   IsVisible="True"
                                   Margin="10,0,0,0" />
                        </StackLayout>

                        <!-- Payment Method -->
                        <StackLayout Spacing="8">
                            <Label Text="Payment Method" 
                                   Style="{StaticResource LabelStyle}"/>
                            <Frame HasShadow="True" 
                                   BorderColor="LightGray"
                                   CornerRadius="12"
                                   Padding="15,5"
                                   BackgroundColor="#F8F9FA"
                                   HeightRequest="50">
                                <Picker Title="Select Payment Method"
                                        FontSize="16"    
                                        x:Name="paymentmethod"
                                        BackgroundColor="Transparent"
                                        HeightRequest="50"
                                        TitleColor="Gray"
                                        TextColor="Black"
                                        HorizontalOptions="FillAndExpand"
                                        SelectedIndexChanged="OnPaymentMethodChanged">
                                    <Picker.ItemsSource>
                                        <x:Array Type="{x:Type x:String}">
                                            <x:String>Cash</x:String>
                                            <x:String>Others Method</x:String>
                                        </x:Array>
                                    </Picker.ItemsSource>
                                </Picker>
                            </Frame>
                        </StackLayout>

                        <!-- Error / Success Message -->
                        <StackLayout x:Name="MessageContainer" IsVisible="False">
                            <Frame x:Name="MessageFrame"
                                   CornerRadius="12"
                                   HasShadow="True"
                                   Padding="15"
                                   Margin="0,5">
                                <StackLayout Orientation="Horizontal" Spacing="10">
                                    <Label x:Name="MessageIcon"
                                           FontSize="18"
                                           VerticalOptions="Center" />
                                    <Label x:Name="MessageLabel"
                                           FontSize="14"
                                           VerticalOptions="Center"
                                           HorizontalOptions="FillAndExpand"
                                           LineBreakMode="WordWrap" />
                                </StackLayout>
                            </Frame>
                        </StackLayout>

                        <!-- ══ Action Buttons ══════════════════════════════════ -->
                        <StackLayout Spacing="5" Margin="0,15,0,0">

                            <!-- Process Payment -->
                            <Button x:Name="VerifyButton"
                                    CornerRadius="10"
                                    HeightRequest="50"
                                    Text="Process Payment"
                                    Clicked="OnVerifyTokenClicked"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    IsEnabled="False"/>

                            <!-- ── REPRINT RECEIPT ──────────────────────────────
                                 Hidden by default.
                                 Becomes visible ONLY when the first print attempt
                                 fails after a successful payment.
                                 ─────────────────────────────────────────────── -->
                            <Button x:Name="ReprintButton"
                                    Text="🖨️ Reprint Receipt"
                                    CornerRadius="10"
                                    HeightRequest="50"
                                    Style="{StaticResource ReprintButtonStyle}"
                                    IsVisible="False"
                                    Clicked="OnReprintReceiptClicked"/>

                            <!-- Cancel -->
                            <Button x:Name="CancelButton"
                                    Text="Cancel" 
                                    CornerRadius="10"
                                    Clicked="OnCancelClicked"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                        </StackLayout>

                        <!-- Generate Invoice link -->
                        <StackLayout Orientation="Horizontal" 
                                     HorizontalOptions="Center"
                                     Spacing="8"
                                     Margin="0,15,0,5">
                            <Label Text="Don't have an Invoice?"
                                   FontSize="14"
                                   TextColor="#636E72" />
                            <Label Text="Generate Invoice"
                                   FontSize="14"
                                   TextColor="ForestGreen"
                                   FontAttributes="Bold"
                                   TextDecorations="Underline">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnResendTokenTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </StackLayout>

                        <!-- Security Notice -->
                        <StackLayout Orientation="Horizontal" 
                                     HorizontalOptions="Center"
                                     Spacing="5"
                                     Margin="0,10,0,10">
                            <Label Text="🔒" FontSize="12" />
                            <Label Text="Your payment is secured with SSL encryption"
                                   FontSize="12"
                                   TextColor="#95A5A6"
                                   HorizontalOptions="Center" />
                        </StackLayout>

                    </StackLayout>
                </ScrollView>
            </Grid>
        </Frame>
    </Grid>
</ContentPage>
